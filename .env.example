# The only required variable:
OPENROUTER_API_KEY=sk-or-...

# Optional overrides (defaults shown):
# AGENT_MODEL=google/gemini-2.5-flash
# CHAIRMAN_MODEL=anthropic/claude-sonnet-4.5
# ROUNDS=3
# START_BALANCE=1000
# BASE_FEE=50
# TOKEN_RATE=0.1
# WIN_REWARD=300
# RUNNERUP_REWARD=100
# REDUNDANCY_FINE=100
# REDUNDANCY_THRESHOLD=7

# Access gate: set a phrase to require it (shown as an ASCII captcha). Empty = open.
# ACCESS_PHRASE=ROUNDTABLE
# DAILY_DEBATE_CAP=0
